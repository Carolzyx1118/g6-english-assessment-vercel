# Required
JWT_SECRET=replace-with-a-long-random-secret
INVITE_CODE=ENGVOC2026=english+vocabulary,MATH2026=math,TEACHER2026=english+math+vocabulary

# Strongly recommended on Vercel for durable users, papers, and history
# Neon provides this as a Postgres connection string.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Required on Vercel if the app needs file uploads or generated assets.
# Choose one storage option:
BLOB_READ_WRITE_TOKEN=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Recommended for AI grading/reporting.
# If set, reading/writing/speaking AI flows will prefer OpenAI over Forge.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Optional Manus OAuth integration
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_OAUTH_PORTAL_URL=

# Optional map proxy integration
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# Optional analytics
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
