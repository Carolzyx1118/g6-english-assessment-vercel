{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm build:vercel",
  "outputDirectory": "public",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/trpc/(.+)",
      "dest": "/api/trpc?trpc=$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
